{
  "name": "solid-three",
  "version": "0.3.0-next.4",
  "description": "SolidJS bindings for ThreeJS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-three.git"
  },
  "module": "./dist/index/index.js",
  "main": "./dist/index/index.js",
  "types": "./dist/index/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**",
    "types/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "vite",
    "lint:circular": "dpdm -T src",
    "lint:code": "eslint --max-warnings 0 src/**/*.{ts,tsx}",
    "lint:types": "tsc --noEmit",
    "prepublishOnly": "pnpm lint:code && pnpm build",
    "test": "vitest",
    "types": "tsc --emitDeclarationOnly --declarationDir types"
  },
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/dev.js"
        }
      },
      "import": {
        "types": "./dist/index/index.d.ts",
        "default": "./dist/index/index.js"
      }
    },
    "./testing": {
      "solid": {
        "development": "./dist/testing/dev.jsx",
        "import": "./dist/testing/index.jsx"
      },
      "development": {
        "import": {
          "types": "./dist/testing/index.d.ts",
          "default": "./dist/testing/dev.js"
        }
      },
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      }
    }
  },
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@solidjs/testing-library": "^0.8.8",
    "@types/node": "^18.19.33",
    "@types/three": "^0.164.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "dpdm": "^3.14.0",
    "esbuild": "^0.21.4",
    "esbuild-register": "^3.5.0",
    "eslint": "^9.32.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "jest": "^29.7.0",
    "jiti": "^2.5.1",
    "jsdom": "^24.1.0",
    "remark-gfm": "^3.0.1",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "solid-app-router": "^0.1.14",
    "solid-js": "^1.8.17",
    "three": "^0.164.1",
    "three-stdlib": "^2.36.0",
    "tsm": "^2.3.0",
    "tsup": "^8.0.2",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.4.5",
    "vite": "5.2.12",
    "vite-plugin-inspect": "0.8.4",
    "vite-plugin-solid": "2.10.2",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@types/three": "*",
    "solid-js": "*",
    "three": "*"
  },
  "jest": {
    "preset": "scripts/jest/node"
  },
  "dependencies": {
    "@solid-primitives/resize-observer": "^2.0.25",
    "debounce": "^2.1.0"
  },
  "browser": {},
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing/index.d.ts"
      ]
    }
  },
  "type": "module"
}
